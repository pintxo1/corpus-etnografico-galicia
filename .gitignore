zenodo/
ZENODO_PACKAGE_SUMMARY.md

#==============================================================================
# PROJECT STRUCTURE - What to KEEP for reproducibility
#==============================================================================

# 01_data: Keep sample, exclude full corpus & regenerable files
01_data/tei/source/*.xml
01_data/tei/source/*.tei.xml
01_data/tei/derived/*
!01_data/tei/sample/
!01_data/README*.md

# 02_methods: KEEP ALL (scripts, config, lexicons)
# No exclusions here - all content should be in GitHub

# 03_analysis: Ignore regenerable analysis, keep ethnographic writing
03_analysis/cases/
03_analysis/reading_pack/
!03_analysis/memos/
!03_analysis/README*.md

# 04_outputs: Keep ONLY case studies & key metadata, ignore intermediate tables
04_outputs/case_cards/
04_outputs/figures/
!04_outputs/tables/corpus_master_table_v2tokens.csv
!04_outputs/tables/emigrant_by_*.csv
!04_outputs/tables/token_mismatch_audit.csv
!04_outputs/README*.md

# 05_freeze: KEEP versioned freeze deliverables
05_freeze/*
!05_freeze/README.md
!05_freeze/*-lite/
!05_freeze/*-lite/**

# 00_docs: KEEP ALL
# No exclusions - all documentation in GitHub

#==============================================================================
# LEGACY & ARCHIVE
#==============================================================================

99_archive/
legacy/
old_scripts/
outputs/
datasets_historicos/
diccionarios/

#==============================================================================
# TEMPORARY & LOG FILES
#==============================================================================

*.log
nohup.out
tmp/
temp/
.cache/
.env
