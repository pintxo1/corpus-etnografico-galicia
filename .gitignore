#==============================================================================
# PROJECT STRUCTURE - What to ignore vs. keep
#==============================================================================

# 01_data: Ignore generated/regenerable files, keep documentation
01_data/tei/source/*.xml
01_data/tei/source/*.tei.xml
01_data/tei/derived/*
01_data/text/*
01_data/kwic_exports/*

# BUT keep documentation in data directories
!01_data/README*.md
!01_data/tei/source/MANIFEST.md
!01_data/tei/sample/
!01_data/external/

# 03_analysis: Ignore regenerable cases and packs, keep ethnographic writing
03_analysis/cases/
03_analysis/reading_pack/

# BUT keep memos directory (ethnographic writing)
!03_analysis/memos/

# 04_outputs: All regenerable (complete ignore)
04_outputs/
!04_outputs/README.md

# 05_freeze: Keep only versioned freezes
05_freeze/*
!05_freeze/README.md
!05_freeze/*-lite/
!05_freeze/*-lite/**

# Legacy/archive (completely ignore)
99_archive/
legacy/
old_scripts/

# Old structure (legacy)
outputs/
datasets_historicos/
!datasets_historicos/README_fuentes.md
scripts/
data/
diccionarios/

# Logs and temporals
*.log
nohup.out
tmp/
temp/
.cache/

99_archive/
